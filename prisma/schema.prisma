generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Utilisateur {
  id            String    @id @default(cuid())
  email         String    @unique
  nom           String
  password      String
  role          String    @default("UTILISATEUR") // ADMINISTRATEUR, ACCUEIL, TECHNIQUE, COMPTABILITE, UTILISATEUR
  actif         Boolean   @default(true)
  avatar        String?
  dernierLogin  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  commentaires  Commentaire[]
  dossiersCrees Dossier[]  @relation("CreateurDossier")
}

model Societe {
  id        String    @id @default(cuid())
  nom       String
  dossiers  Dossier[]
  contrats  Contrat[]
  createdAt DateTime  @default(now())
}

model Gestionnaire {
  id                  String    @id @default(cuid())
  nom                 String
  service             String
  dossiersAccueil     Dossier[] @relation("GestionnaireAccueil")
  dossiersTechnique   Dossier[] @relation("GestionnaireTechnique")
  dossiersCompta      Dossier[] @relation("GestionnaireCompta")
  createdAt           DateTime  @default(now())
}

model Contrat {
  id              String    @id @default(cuid())
  societeId       String
  societe         Societe   @relation(fields: [societeId], references: [id])
  reference       String
  budgetAnnuel    Float
  budgetUtilise   Float     @default(0)
  dateDebut       DateTime
  dateFin         DateTime
  statut          String    @default("ACTIF") // ACTIF, EXPIRE, SUSPENDU
  appelsDeFonds   AppelDeFonds[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model AppelDeFonds {
  id            String    @id @default(cuid())
  contratId     String
  contrat       Contrat   @relation(fields: [contratId], references: [id])
  montant       Float
  dateAppel     DateTime
  datePaiement  DateTime?
  reference     String?
  statut        String    @default("EN_ATTENTE") // EN_ATTENTE, PARTIELLEMENT_REGLE, REGLE
  observations  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Dossier {
  id                        String       @id @default(cuid())
  numeroDossier             String       @unique
  dateReception             DateTime
  societeId                 String
  societe                   Societe      @relation(fields: [societeId], references: [id])
  beneficiaire              String
  typeDossier               String
  gestionnaireAccueilId     String?
  gestionnaireAccueil       Gestionnaire? @relation("GestionnaireAccueil", fields: [gestionnaireAccueilId], references: [id])
  createurId                String?
  createur                  Utilisateur?  @relation("CreateurDossier", fields: [createurId], references: [id])

  // Informations complémentaires du cahier des charges
  assure                    String?
  nSS                       String?       // Numéro de sécurité sociale
  prestataire               String?       // Nom du prestataire médical
  dateSoins                 DateTime?     // Date des soins
  moyenPaiement             String?       // VIREMENT, CHEQUE, ESPECES
  observations              String?

  // Traitement technique
  dateTraitementTechnique   DateTime?
  montantReclame            Float
  montantValide             Float?
  ticketModerateur          Float?
  partPatient               Float?
  partEntreprise            Float?
  gestionnaireTechniqueId   String?
  gestionnaireTechnique     Gestionnaire? @relation("GestionnaireTechnique", fields: [gestionnaireTechniqueId], references: [id])
  motifRejet                String?

  // Comptabilité et paiement
  dateReceptionDecompte     DateTime?
  datePaiement              DateTime?
  referencePaiement         String?
  montantPaye               Float?
  gestionnaireComptaId      String?
  gestionnaireCompta        Gestionnaire? @relation("GestionnaireCompta", fields: [gestionnaireComptaId], references: [id])

  // État et traçabilité
  statut                    String       @default("RECU") // RECU, EN_ANALYSE, VALIDE, EN_COMPTABILITE, EN_PAIEMENT, PAYE, REJETE
  source                    String       @default("EXCEL") // EXCEL, ISA, SAGE, MANUEL
  historique                String       @default("[]") // JSON array of {date, statut, userId, commentaire}

  createdAt                 DateTime     @default(now())
  updatedAt                 DateTime     @updatedAt

  // Relations
  commentaires              Commentaire[]
  justificatifs             Justificatif[]
  importations              ImportDossier[]
}

model Commentaire {
  id          String   @id @default(cuid())
  dossierId   String
  dossier     Dossier  @relation(fields: [dossierId], references: [id], onDelete: Cascade)
  auteurId    String?
  auteur      Utilisateur? @relation(fields: [auteurId], references: [id])
  contenu     String
  prive       Boolean  @default(false) // true = visible uniquement par l'équipe interne
  createdAt   DateTime @default(now())
}

model Justificatif {
  id          String   @id @default(cuid())
  dossierId   String
  dossier     Dossier  @relation(fields: [dossierId], references: [id], onDelete: Cascade)
  type        String   // FACTURE, ORDONNANCE, RIB, CARNET_SOINS, DECOMPTE, AUTRE
  nomFichier  String
  chemin      String
  tailleKo    Float?
  uploadedBy  String?
  createdAt   DateTime @default(now())
}

model ImportHistorique {
  id            String   @id @default(cuid())
  source        String   // ISA, SAGE, EXCEL
  nomFichier    String
  nbLignes      Int
  nbSucces      Int      @default(0)
  nbErreurs     Int      @default(0)
  rapport       String   @default("[]") // JSON array of anomalies
  importePar    String?
  createdAt     DateTime @default(now())
  dossiers      ImportDossier[]
}

model ImportDossier {
  id               String         @id @default(cuid())
  importId         String
  importHistorique ImportHistorique @relation(fields: [importId], references: [id])
  dossierId        String?
  dossier          Dossier?       @relation(fields: [dossierId], references: [id])
  numeroLigne      Int
  statutImport     String         @default("SUCCES") // SUCCES, ERREUR, IGNORE
  erreur           String?
  donnees          String         @default("{}") // JSON des données brutes de la ligne
}